{"manifest_version": 3, "name": "Surprise Tab", "version": "1.0.0", "description": "每天打开新标签页，收获一份惊喜——互动小游戏、生成艺术、AI 冷笑话，每天不重样！", "permissions": ["storage", "alarms"], "host_permissions": ["https://*/*"], "background": {"service_worker": "background.js", "type": "module"}, "chrome_url_overrides": {"newtab": "newtab.html"}, "options_page": "options.html", "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}, "action": {"default_title": "Surprise Tab 设置", "default_icon": {"16": "icons/icon16.png", "48": "icons/icon48.png"}}}